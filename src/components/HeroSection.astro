---
import { Image } from 'astro:assets';
import { SITE, WA_MESSAGES } from '../config/site.ts';

// Slider: una imagen de cada carpeta/categoría
import sliderCollares  from '../assets/collares/Aguacatito.jpg';
import sliderAnillos   from '../assets/anillos/Corazon Bolita.jpg';
import sliderAretes    from '../assets/aretes/Corazon Mini.jpg';
import sliderPulseras  from '../assets/pulseras/Mini Corazones.jpg';
import sliderHombres   from '../assets/hombres/Cadena cordon Dorada.png';

const sliderImages = [
  { src: sliderCollares, label: 'Collar Aguacatito de acero inoxidable' },
  { src: sliderAnillos,  label: 'Anillo Corazón Bolita de acero inoxidable' },
  { src: sliderAretes,   label: 'Aretes Corazón Mini de acero inoxidable' },
  { src: sliderPulseras, label: 'Pulsera Mini Corazones de acero inoxidable' },
  { src: sliderHombres,  label: 'Cadena Cordón para hombre de acero inoxidable' },
];

interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  ctaText?: string;
}

const {
  eyebrow = `${SITE.city}, ${SITE.country}`,
  title,
  subtitle,
  ctaText = 'Consultar por WhatsApp',
} = Astro.props;

const waUrl = SITE.phone
  ? `https://wa.me/${SITE.phone}?text=${encodeURIComponent(WA_MESSAGES.general)}`
  : '/contacto';
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__inner">

    <div class="hero__content">
      <span class="hero__eyebrow">{eyebrow}</span>
      <h1 id="hero-heading">{title}</h1>
      <p class="hero__sub">{subtitle}</p>
      <a
        href={waUrl}
        class="hero__cta"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Abrir WhatsApp para consultar"
      >
        <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M16 3C8.82 3 3 8.82 3 16c0 2.37.63 4.63 1.75 6.59L3 29l6.6-1.72A13 13 0 0016 29c7.18 0 13-5.82 13-13S23.18 3 16 3zm-3.02 7.5c-.3-.67-.62-.68-.91-.69l-.77-.01c-.27 0-.7.1-1.07.5-.37.4-1.4 1.36-1.4 3.32s1.44 3.85 1.64 4.12c.2.27 2.78 4.44 6.84 6.05 3.38 1.34 4.07 1.07 4.8 1.01.73-.06 2.36-.96 2.7-1.9.33-.93.33-1.73.23-1.9-.1-.17-.37-.27-.77-.47s-2.37-1.17-2.74-1.3c-.37-.14-.63-.2-.9.2-.27.4-.73.93-.9 1.13-.17.2-.33.22-.7.07-.37-.17-1.56-.57-2.97-1.83-1.1-.98-1.84-2.19-2.06-2.56-.21-.37-.02-.57.16-.75.16-.16.37-.42.56-.63.18-.2.24-.34.37-.57.12-.23.06-.43-.03-.63-.1-.2-.87-2.1-1.2-2.87z" fill="currentColor"/>
        </svg>
        {ctaText}
      </a>
    </div>

    <!-- Slider de imágenes de productos -->
    <div class="hero__slider" aria-label="Muestra de productos">
      <div class="hero__slides-wrap">
        {sliderImages.map((item, i) => (
          <div class={`hero__slide${i === 0 ? ' hero__slide--active' : ''}`} aria-hidden={i !== 0}>
            <Image
              src={item.src}
              alt={item.label}
              width={420}
              height={420}
              format="webp"
              quality={82}
              loading={i === 0 ? 'eager' : 'lazy'}
              class="hero__slide-img"
            />
          </div>
        ))}
      </div>
      <div class="hero__dots" role="tablist" aria-label="Navegación del carrusel">
        {sliderImages.map((_, i) => (
          <button
            class={`hero__dot${i === 0 ? ' hero__dot--active' : ''}`}
            data-index={i}
            role="tab"
            aria-selected={i === 0}
            aria-label={`Imagen ${i + 1} de ${sliderImages.length}`}
          ></button>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  const slides  = Array.from(document.querySelectorAll<HTMLElement>('.hero__slide'));
  const dots    = Array.from(document.querySelectorAll<HTMLElement>('.hero__dot'));
  let current   = 0;
  let animating = false;
  let timer: ReturnType<typeof setInterval>;

  function goTo(next: number) {
    if (animating || next === current) return;
    animating = true;

    const prev = current;
    current = next;

    // Salida: slide actual sube y desvanece
    slides[prev].classList.add('hero__slide--exit');
    slides[prev].classList.remove('hero__slide--active');
    dots[prev].classList.remove('hero__dot--active');
    dots[prev].setAttribute('aria-selected', 'false');

    // Entrada: siguiente slide sube desde abajo
    slides[current].classList.add('hero__slide--active');
    dots[current].classList.add('hero__dot--active');
    dots[current].setAttribute('aria-selected', 'true');

    setTimeout(() => {
      slides[prev].classList.remove('hero__slide--exit');
      animating = false;
    }, 700);
  }

  function next() {
    goTo((current + 1) % slides.length);
  }

  timer = setInterval(next, 3800);

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearInterval(timer);
      goTo(i);
      timer = setInterval(next, 3800);
    });
  });
</script>

<style>
  /* Layout dos columnas */
  .hero__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
    text-align: left;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .hero__content {
    flex: 1;
    min-width: 0;
  }

  /* Slider container */
  .hero__slider {
    flex: 0 0 380px;
    max-width: 380px;
  }

  /* Contenedor de slides con altura fija */
  .hero__slides-wrap {
    position: relative;
    width: 100%;
    padding-bottom: 100%; /* cuadrado 1:1 */
  }

  /* Todos los slides absolutos - evita el salto de layout */
  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.7s ease, transform 0.7s ease;
    pointer-events: none;
  }

  /* Slide activo: visible y en posición */
  .hero__slide--active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Slide saliendo: sube hacia arriba y desvanece */
  .hero__slide--exit {
    opacity: 0;
    transform: translateY(-18px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    pointer-events: none;
  }

  .hero__slide-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 20px;
    filter: drop-shadow(0 8px 32px rgba(0,0,0,0.45));
  }

  /* Dots indicadores */
  .hero__dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 18px;
  }

  .hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.35);
    cursor: pointer;
    padding: 0;
    transition: background 0.3s, transform 0.3s;
  }

  .hero__dot--active {
    background: var(--color-accent);
    transform: scale(1.4);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero__inner {
      flex-direction: column;
      text-align: center;
      gap: 32px;
    }

    .hero__slider {
      flex: none;
      max-width: 260px;
      width: 100%;
    }

    .hero__content {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
  }
</style>
