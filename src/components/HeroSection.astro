---
import { SITE, WA_MESSAGES } from '../config/site.ts';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  ctaText?: string;
  image?: ImageMetadata;
  imageAlt?: string;
}

const {
  eyebrow = `${SITE.city}, ${SITE.country}`,
  title,
  subtitle,
  ctaText = 'Consultar por WhatsApp',
  image,
  imageAlt = '',
} = Astro.props;

const waUrl = SITE.phone
  ? `https://wa.me/${SITE.phone}?text=${encodeURIComponent(WA_MESSAGES.general)}`
  : '/contacto';
---

<section class={`hero${image ? ' hero--with-image' : ''}`} aria-labelledby="hero-heading">
  <div class="hero__inner">

    <div class="hero__content">
      <span class="hero__eyebrow">{eyebrow}</span>
      <h1 id="hero-heading">{title}</h1>
      <p class="hero__sub">{subtitle}</p>
      <a
        href={waUrl}
        class="hero__cta"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Abrir WhatsApp para consultar"
      >
        <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M16 3C8.82 3 3 8.82 3 16c0 2.37.63 4.63 1.75 6.59L3 29l6.6-1.72A13 13 0 0016 29c7.18 0 13-5.82 13-13S23.18 3 16 3zm-3.02 7.5c-.3-.67-.62-.68-.91-.69l-.77-.01c-.27 0-.7.1-1.07.5-.37.4-1.4 1.36-1.4 3.32s1.44 3.85 1.64 4.12c.2.27 2.78 4.44 6.84 6.05 3.38 1.34 4.07 1.07 4.8 1.01.73-.06 2.36-.96 2.7-1.9.33-.93.33-1.73.23-1.9-.1-.17-.37-.27-.77-.47s-2.37-1.17-2.74-1.3c-.37-.14-.63-.2-.9.2-.27.4-.73.93-.9 1.13-.17.2-.33.22-.7.07-.37-.17-1.56-.57-2.97-1.83-1.1-.98-1.84-2.19-2.06-2.56-.21-.37-.02-.57.16-.75.16-.16.37-.42.56-.63.18-.2.24-.34.37-.57.12-.23.06-.43-.03-.63-.1-.2-.87-2.1-1.2-2.87z" fill="currentColor"/>
        </svg>
        {ctaText}
      </a>
    </div>

    {image && (
      <div class="hero__image">
        <Image
          src={image}
          alt={imageAlt}
          width={420}
          height={420}
          loading="eager"
          class="hero__img"
        />
      </div>
    )}

  </div>
</section>

<style>
  /* Layout con imagen: dos columnas en desktop */
  .hero--with-image .hero__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
    text-align: left;
    max-width: 1100px;
  }

  .hero__content {
    flex: 1;
    min-width: 0;
  }

  .hero--with-image .hero__sub {
    margin-left: 0;
    margin-right: 0;
  }

  .hero__image {
    flex: 0 0 380px;
    max-width: 380px;
  }

  .hero__img {
    width: 100%;
    height: auto;
    border-radius: 20px;
    object-fit: contain;
    filter: drop-shadow(0 8px 32px rgba(0,0,0,0.35));
  }

  /* Mobile: vuelve a columna, imagen debajo */
  @media (max-width: 768px) {
    .hero--with-image .hero__inner {
      flex-direction: column;
      text-align: center;
      gap: 32px;
    }

    .hero--with-image .hero__sub {
      margin-left: auto;
      margin-right: auto;
    }

    .hero__image {
      flex: none;
      max-width: 260px;
      width: 100%;
    }
  }
</style>
