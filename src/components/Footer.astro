---
import { SITE, CATEGORIAS, SOCIAL } from '../config/site.ts';
const siteName = SITE.name || 'Joyería Salomé';
const year = new Date().getFullYear();
---

<footer>
  <div class="footer__inner">

    <!-- Marca -->
    <div>
      <p class="footer__brand">{siteName}</p>
      <p class="footer__text">
        Joyería de acero inoxidable quirúrgico 316L en {SITE.city}, {SITE.country}.<br />
        Joyas que no se oxidan y duran años.
      </p>
    </div>

    <!-- Categorías -->
    <div>
      <p class="footer__heading">Categorías</p>
      <ul class="footer__links">
        {CATEGORIAS.map(cat => (
          <li><a href={`/${cat.slug}`}>{cat.nombre}</a></li>
        ))}
      </ul>
    </div>

    <!-- Navegación -->
    <div>
      <p class="footer__heading">Navegación</p>
      <ul class="footer__links">
        <li><a href="/">Inicio</a></li>
        <li><a href="/nosotros">Nosotros</a></li>
        <li><a href="/contacto">Contacto</a></li>
      </ul>
    </div>

    <!-- Contacto y redes -->
    <div>
      <p class="footer__heading">Contacto</p>
      <p class="footer__text">
        {SITE.city}, {SITE.country}<br />
        {SITE.phone ? (
          <a
            href={`https://wa.me/${SITE.phone}`}
            style="color: #25D366; font-weight: 600;"
            target="_blank"
            rel="noopener"
          >
            WhatsApp
          </a>
        ) : 'WhatsApp disponible próximamente'}
      </p>
      <div class="footer__social">
        <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram de Joyería Salomé">
          <!-- Instagram -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="currentColor" stroke-width="2"/>
            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
          </svg>
        </a>
        <a href={SOCIAL.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook de Joyería Salomé">
          <!-- Facebook -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href={SOCIAL.tiktok} target="_blank" rel="noopener noreferrer" aria-label="TikTok de Joyería Salomé">
          <!-- TikTok -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

  </div>

  <div class="footer__bottom">
    <p>
      &copy; {year} {siteName}. Todos los derechos reservados.
      &mdash; {SITE.city}, {SITE.country}
    </p>
  </div>
</footer>

<style>
  .footer__social {
    display: flex;
    gap: 14px;
    margin-top: 12px;
  }
  .footer__social a {
    color: var(--color-text-light, #aaa);
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }
  .footer__social a:hover {
    color: var(--color-accent, #c9a96e);
  }
</style>
