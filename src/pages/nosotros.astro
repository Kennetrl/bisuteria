---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, WA_MESSAGES } from '../config/site.ts';

const siteName = SITE.name || 'Joyería Salomé';
const title = 'Sobre Nosotros';
const description = `Conoce Joyería Salomé, tu tienda de joyería de acero inoxidable quirúrgico 316L en ${SITE.city}, ${SITE.country}. Joyas que no se oxidan, no se ennegrecen y duran años.`;

const waUrl = SITE.phone
  ? `https://wa.me/${SITE.phone}?text=${encodeURIComponent(WA_MESSAGES.nosotros)}`
  : '#';

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": `${title} | ${siteName}`,
  "description": description,
  "url": `${SITE.url}/nosotros`,
  "isPartOf": {
    "@type": "WebSite",
    "name": siteName,
    "url": SITE.url
  }
};
---

<BaseLayout
  title="Sobre Nosotros - Joyería de Acero Inoxidable en Quito"
  description={description}
  canonical="/nosotros"
  schema={schema}
  keywords="joyería de acero quirúrgico 316L, por qué comprar joyería de acero inoxidable, diferencia joyería fantasía vs acero inoxidable, joyas que duran años Quito"
>

  <div class="page-header">
    <h1>{title}</h1>
    <p>Conoce quiénes somos y por qué nuestras joyas duran años</p>
  </div>

  <nav class="breadcrumb" aria-label="Ruta de navegación">
    <a href="/">Inicio</a>
    <span aria-hidden="true">›</span>
    <span aria-current="page">Nosotros</span>
  </nav>

  <div class="content-page">

    <h2>Nuestra historia</h2>
    <p>
      Joyería Salomé nació en {SITE.city}, {SITE.country}, de la pasión por los accesorios de verdadera calidad.
      Cansadas de ver joyas que se oxidan, se ennegrecen o pierden el color a los pocos meses,
      decidimos ofrecer algo diferente: joyería de acero inoxidable quirúrgico 316L que dura años.
    </p>
    <p>
      Sabemos que un outfit sin accesorios se ve simple. Un collar, unas pulseras o unos aretes
      hacen que todo resalte. Por eso seleccionamos cuidadosamente cada pieza: diseños elegantes
      que elevan cualquier look, con la garantía de que no van a desgastarse.
    </p>

    <h2>¿Qué es el Acero Quirúrgico 316L?</h2>
    <p>
      El Acero Inoxidable Quirúrgico 316L es el material de mayor calidad en joyería duradera.
      A diferencia de la joyería de fantasía que usa metales de baja calidad con baño superficial,
      el acero 316L es resistente al agua, al sudor y al paso del tiempo. No se oxida, no se
      ennegrece y no pierde el brillo — tus joyas van a lucir igual de bonitas en años.
    </p>

    <h2>Nuestra misión</h2>
    <p>
      Que cada persona pueda lucir accesorios de buena calidad sin preocuparse por el desgaste.
      Joyas resistentes al agua que puedes usar todos los días, en la piscina, en el gimnasio,
      o en cualquier ocasión — y que siempre van a verse impecables.
    </p>

    <h2>¿Por qué elegirnos?</h2>
    <p>
      Trabajamos exclusivamente con joyería de acero inoxidable quirúrgico 316L. Atención
      personalizada por WhatsApp, variedad de diseños y la tranquilidad de saber que tus joyas
      no se van a arruinar. Estamos en {SITE.city} y coordinamos entrega o retiro según tu preferencia.
    </p>

    <a href={waUrl} class="contact-wa" target="_blank" rel="noopener noreferrer">
      <svg width="22" height="22" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M16 3C8.82 3 3 8.82 3 16c0 2.37.63 4.63 1.75 6.59L3 29l6.6-1.72A13 13 0 0016 29c7.18 0 13-5.82 13-13S23.18 3 16 3zm-3.02 7.5c-.3-.67-.62-.68-.91-.69l-.77-.01c-.27 0-.7.1-1.07.5-.37.4-1.4 1.36-1.4 3.32s1.44 3.85 1.64 4.12c.2.27 2.78 4.44 6.84 6.05 3.38 1.34 4.07 1.07 4.8 1.01.73-.06 2.36-.96 2.7-1.9.33-.93.33-1.73.23-1.9-.1-.17-.37-.27-.77-.47s-2.37-1.17-2.74-1.3c-.37-.14-.63-.2-.9.2-.27.4-.73.93-.9 1.13-.17.2-.33.22-.7.07-.37-.17-1.56-.57-2.97-1.83-1.1-.98-1.84-2.19-2.06-2.56-.21-.37-.02-.57.16-.75.16-.16.37-.42.56-.63.18-.2.24-.34.37-.57.12-.23.06-.43-.03-.63-.1-.2-.87-2.1-1.2-2.87z" fill="currentColor"/>
      </svg>
      Escríbenos por WhatsApp
    </a>

  </div>

</BaseLayout>
