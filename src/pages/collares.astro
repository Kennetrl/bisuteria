---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { SITE, WA_MESSAGES } from '../config/site.ts';
import type { ImageMetadata } from 'astro';

// Importar todas las imágenes de collares (Astro convierte a WebP en build)
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/collares/*.png',
  { eager: true }
);

// Ordenar numéricamente por nombre de archivo
const images = Object.entries(imageModules)
  .sort(([a], [b]) => {
    const numA = parseInt(a.replace(/\D/g, ''));
    const numB = parseInt(b.replace(/\D/g, ''));
    return numA - numB;
  })
  .map(([_, mod]) => mod.default);

const siteName = SITE.name || 'Bisutería Quito';
const title = 'Collares de Bisutería';
const description = `Collares de bisutería y accesorios en ${SITE.city}, ${SITE.country}. Colección de ${images.length} diseños elegantes y modernos. Consulta disponibilidad por WhatsApp.`;

// JSON-LD: ItemList
const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `${title} | ${siteName}`,
  "description": description,
  "url": `${SITE.url}/collares`,
  "numberOfItems": images.length,
  "itemListElement": images.map((_, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `${SITE.url}/collares#producto-${i + 1}`
  }))
};
---

<BaseLayout
  title={`${title} | ${siteName} - ${SITE.city}, ${SITE.country}`}
  description={description}
  canonical="/collares"
  schema={schema}
>

  <!-- Page Header -->
  <div class="page-header">
    <h1>{title}</h1>
    <p>Colección de {images.length} diseños — {SITE.city}, {SITE.country}</p>
  </div>

  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Ruta de navegación">
    <a href="/">Inicio</a>
    <span aria-hidden="true">›</span>
    <span aria-current="page">Collares</span>
  </nav>

  <!-- Productos -->
  <section class="section" aria-label="Catálogo de collares">
    <div class="products-grid">
      {images.map((img, i) => (
        <ProductCard
          image={img}
          alt={`Collar de bisutería número ${i + 1} - ${siteName} ${SITE.city}`}
          waMessage={WA_MESSAGES.collares}
          index={i}
        />
      ))}
    </div>
  </section>

</BaseLayout>
