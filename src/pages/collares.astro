---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { SITE, WA_MESSAGES } from '../config/site.ts';
import type { ImageMetadata } from 'astro';

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/collares/*.png',
  { eager: true }
);

const images = Object.entries(imageModules)
  .sort(([a], [b]) => parseInt(a.replace(/\D/g, '')) - parseInt(b.replace(/\D/g, '')))
  .map(([_, mod]) => mod.default);

const siteName = SITE.name || 'Joyería Salomé';
const title = `Collares de Acero Inoxidable en ${SITE.city}`;
const description = `Collares de acero inoxidable quirúrgico 316L en ${SITE.city}, ${SITE.country}. ${images.length} diseños que no se oxidan, no se ennegrecen y son resistentes al agua. Joyas de buena calidad que duran años.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Collares de Acero Inoxidable | ${siteName}`,
  "description": description,
  "url": `${SITE.url}/collares`,
  "numberOfItems": images.length,
  "itemListElement": images.map((_, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `${SITE.url}/collares#producto-${i + 1}`
  }))
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/collares"
  schema={schema}
  keywords="collares de acero inoxidable, collares que no se oxidan, collares resistentes al agua, collares que no se ennegrecen, collares de buena calidad"
>

  <div class="page-header">
    <h1>Collares de Acero Inoxidable</h1>
    <p>Acero Quirúrgico 316L · No se oxidan · Resistentes al agua · {images.length} diseños</p>
  </div>

  <nav class="breadcrumb" aria-label="Ruta de navegación">
    <a href="/">Inicio</a>
    <span aria-hidden="true">›</span>
    <span aria-current="page">Collares</span>
  </nav>

  <div class="seo-intro">
    <p>
      Nuestros collares de acero inoxidable quirúrgico 316L no se oxidan, no se ennegrecen ni pierden el brillo con el tiempo.
      Úsalos a diario, en la piscina o bajo la lluvia — están hechos para durar años sin desgastarse.
      El accesorio perfecto para elevar cualquier outfit con estilo y elegancia.
    </p>
  </div>

  <section class="section" aria-label="Catálogo de collares de acero inoxidable">
    <div class="products-grid">
      {images.map((img, i) => (
        <ProductCard
          image={img}
          alt={`Collar de acero inoxidable ${i + 1} - joya que no se oxida ni se ennegrece - ${siteName} ${SITE.city}`}
          waMessage={WA_MESSAGES.collares}
          index={i}
        />
      ))}
    </div>
  </section>

</BaseLayout>

<style>
  .seo-intro {
    max-width: 860px;
    margin: 0 auto;
    padding: 32px 24px 0;
  }
  .seo-intro p {
    color: var(--color-text-light);
    line-height: 1.75;
    font-size: 1rem;
  }
</style>
