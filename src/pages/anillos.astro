---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { SITE, WA_MESSAGES } from '../config/site.ts';
import type { ImageMetadata } from 'astro';

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/anillos/*.png',
  { eager: true }
);

const images = Object.entries(imageModules)
  .sort(([a], [b]) => parseInt(a.replace(/\D/g, '')) - parseInt(b.replace(/\D/g, '')))
  .map(([_, mod]) => mod.default);

const siteName = SITE.name || 'Joyería Salomé';
const title = `Anillos de Acero Inoxidable en ${SITE.city}`;
const description = `Anillos de acero inoxidable quirúrgico 316L en ${SITE.city}, ${SITE.country}. ${images.length} modelos que no se oxidan, no pierden el color y duran años. Joyas de buena calidad resistentes al agua.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Anillos de Acero Inoxidable | ${siteName}`,
  "description": description,
  "url": `${SITE.url}/anillos`,
  "numberOfItems": images.length,
  "itemListElement": images.map((_, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `${SITE.url}/anillos#producto-${i + 1}`
  }))
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/anillos"
  schema={schema}
  keywords="anillos de acero inoxidable, anillos que no se oxidan, anillos que no se ennegrecen, anillos resistentes al agua, anillos que duran años"
>

  <div class="page-header">
    <h1>Anillos de Acero Inoxidable</h1>
    <p>Acero Quirúrgico 316L · No se ennegrecen · Resistentes al agua · {images.length} diseños</p>
  </div>

  <nav class="breadcrumb" aria-label="Ruta de navegación">
    <a href="/">Inicio</a>
    <span aria-hidden="true">›</span>
    <span aria-current="page">Anillos</span>
  </nav>

  <div class="seo-intro">
    <p>
      Anillos de acero inoxidable quirúrgico 316L que mantienen su brillo y color por años.
      No se oxidan, no se ennegrecen y son resistentes al agua y al sudor — ideales para usar todos los días.
      Elige el tuyo y complementa tu look con una joya de verdadera calidad.
    </p>
  </div>

  <section class="section" aria-label="Catálogo de anillos de acero inoxidable">
    <div class="products-grid">
      {images.map((img, i) => (
        <ProductCard
          image={img}
          alt={`Anillo de acero inoxidable ${i + 1} - joya que no se oxida - ${siteName} ${SITE.city}`}
          waMessage={WA_MESSAGES.anillos}
          index={i}
        />
      ))}
    </div>
  </section>

</BaseLayout>

<style>
  .seo-intro {
    max-width: 860px;
    margin: 0 auto;
    padding: 32px 24px 0;
  }
  .seo-intro p {
    color: var(--color-text-light);
    line-height: 1.75;
    font-size: 1rem;
  }
</style>
