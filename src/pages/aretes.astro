---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { SITE, WA_MESSAGES } from '../config/site.ts';
import type { ImageMetadata } from 'astro';

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/aretes/*.jpg',
  { eager: true }
);

const images = Object.entries(imageModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([path, mod]) => ({
    src: mod.default,
    name: path.split('/').pop()?.replace('.jpg', '') || '',
  }));

const siteName = SITE.name || 'Joyería Salomé';
const title = `Aretes de Acero Inoxidable en ${SITE.city}`;
const description = `Aretes y pendientes de acero inoxidable quirúrgico 316L en ${SITE.city}, ${SITE.country}. ${images.length} estilos — argollas, colgantes y más. No se oxidan y son resistentes al agua.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Aretes de Acero Inoxidable | ${siteName}`,
  "description": description,
  "url": `${SITE.url}/aretes`,
  "numberOfItems": images.length,
  "itemListElement": images.map((_, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `${SITE.url}/aretes#producto-${i + 1}`
  }))
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/aretes"
  schema={schema}
  keywords="aretes de acero inoxidable, aretes que no se oxidan, aretes resistentes al agua, pendientes de acero inoxidable, aretes que duran años"
>

  <div class="page-header">
    <h1>Aretes de Acero Inoxidable</h1>
    <p>Acero Quirúrgico 316L · No se oxidan · Resistentes al agua · {images.length} diseños</p>
  </div>

  <nav class="breadcrumb" aria-label="Ruta de navegación">
    <a href="/">Inicio</a>
    <span aria-hidden="true">›</span>
    <span aria-current="page">Aretes</span>
  </nav>

  <div class="seo-intro">
    <p>
      Aretes de acero inoxidable quirúrgico 316L: argollas, colgantes y más estilos que no se oxidan ni pierden el brillo.
      Resistentes al agua y al uso diario, son la alternativa duradera frente a los aretes de joyería de fantasía que se oxidan.
      Encuentra el par perfecto para resaltar tu estilo.
    </p>
  </div>

  <section class="section" aria-labelledby="aretes-heading">
    <h2 class="section__title" id="aretes-heading">Catálogo de Aretes</h2>
    <div class="section__divider"></div>
    <div class="products-grid">
      {images.map((item, i) => (
        <ProductCard
          image={item.src}
          alt={`Aretes ${item.name} de acero inoxidable - no se oxidan - ${siteName} ${SITE.city}`}
          name={item.name}
          waMessage={WA_MESSAGES.aretes}
          index={i}
        />
      ))}
    </div>
  </section>

</BaseLayout>

<style>
  .seo-intro {
    max-width: 860px;
    margin: 0 auto;
    padding: 32px 24px 0;
  }
  .seo-intro p {
    color: var(--color-text-light);
    line-height: 1.75;
    font-size: 1rem;
  }
</style>
