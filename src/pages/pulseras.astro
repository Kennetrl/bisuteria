---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { SITE, WA_MESSAGES } from '../config/site.ts';
import type { ImageMetadata } from 'astro';

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/pulseras/*.jpg',
  { eager: true }
);

const images = Object.entries(imageModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([path, mod]) => ({
    src: mod.default,
    name: path.split('/').pop()?.replace('.jpg', '') || '',
  }));

const siteName = SITE.name || 'Joyería Salomé';
const title = `Pulseras de Acero Inoxidable en ${SITE.city}`;
const description = `Pulseras de acero inoxidable quirúrgico 316L en ${SITE.city}, ${SITE.country}. ${images.length} diseños que no se oxidan, no pierden el brillo y duran años. Pulseras resistentes al agua de buena calidad.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Pulseras de Acero Inoxidable | ${siteName}`,
  "description": description,
  "url": `${SITE.url}/pulseras`,
  "numberOfItems": images.length,
  "itemListElement": images.map((_, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `${SITE.url}/pulseras#producto-${i + 1}`
  }))
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/pulseras"
  schema={schema}
  keywords="pulseras de acero inoxidable, pulseras que duran, pulseras que no se oxidan, pulseras resistentes al agua, pulseras de buena calidad"
>

  <div class="page-header">
    <h1>Pulseras de Acero Inoxidable</h1>
    <p>Acero Quirúrgico 316L · No se oxidan · Pulseras que duran años · {images.length} diseños</p>
  </div>

  <nav class="breadcrumb" aria-label="Ruta de navegación">
    <a href="/">Inicio</a>
    <span aria-hidden="true">›</span>
    <span aria-current="page">Pulseras</span>
  </nav>

  <div class="seo-intro">
    <p>
      Pulseras de acero inoxidable quirúrgico 316L diseñadas para durar años.
      No se oxidan y son completamente resistentes al agua — puedes usarlas en la piscina, en el gimnasio o en cualquier ocasión.
      El complemento ideal para cualquier outfit, con la garantía de que siempre van a lucir igual de bonitas.
    </p>
  </div>

  <section class="section" aria-labelledby="pulseras-heading">
    <h2 class="section__title" id="pulseras-heading">Catálogo de Pulseras</h2>
    <div class="section__divider"></div>
    <div class="products-grid">
      {images.map((item, i) => (
        <ProductCard
          image={item.src}
          alt={`Pulsera ${item.name} de acero inoxidable - no se oxida - ${siteName} ${SITE.city}`}
          name={item.name}
          waMessage={WA_MESSAGES.pulseras}
          index={i}
        />
      ))}
    </div>
  </section>

</BaseLayout>

<style>
  .seo-intro {
    max-width: 860px;
    margin: 0 auto;
    padding: 32px 24px 0;
  }
  .seo-intro p {
    color: var(--color-text-light);
    line-height: 1.75;
    font-size: 1rem;
  }
</style>
