---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, CATEGORIAS, WA_MESSAGES, SOCIAL } from '../config/site.ts';

const siteName = SITE.name || 'Joyería Salomé';
const title = 'Contacto';
const description = `Contáctanos por WhatsApp para consultas sobre joyería de acero inoxidable en ${SITE.city}, ${SITE.country}. Atención directa y personalizada.`;

const waUrl = SITE.phone
  ? `https://wa.me/${SITE.phone}?text=${encodeURIComponent(WA_MESSAGES.contacto)}`
  : '#';

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": `${title} | ${siteName}`,
  "description": description,
  "url": `${SITE.url}/contacto`
};
---

<BaseLayout
  title="Contacto - Consulta tu Joyería de Acero Inoxidable por WhatsApp"
  description={description}
  canonical="/contacto"
  schema={schema}
  keywords="contacto joyería Quito, comprar joyería de acero inoxidable WhatsApp, consultar joyas acero 316L Ecuador"
>

  <div class="page-header">
    <h1>Contáctanos</h1>
    <p>Estamos aquí para ayudarte — escríbenos cuando quieras</p>
  </div>

  <nav class="breadcrumb" aria-label="Ruta de navegación">
    <a href="/">Inicio</a>
    <span aria-hidden="true">›</span>
    <span aria-current="page">Contacto</span>
  </nav>

  <div class="content-page">

    <h2>WhatsApp</h2>
    <p>
      La forma más rápida de contactarnos es por WhatsApp.
      Respondemos todos los días para ayudarte a elegir tu joyería de acero inoxidable,
      consultar disponibilidad y coordinar la entrega en {SITE.city}.
    </p>

    <a href={waUrl} class="contact-wa" target="_blank" rel="noopener noreferrer">
      <svg width="22" height="22" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M16 3C8.82 3 3 8.82 3 16c0 2.37.63 4.63 1.75 6.59L3 29l6.6-1.72A13 13 0 0016 29c7.18 0 13-5.82 13-13S23.18 3 16 3zm-3.02 7.5c-.3-.67-.62-.68-.91-.69l-.77-.01c-.27 0-.7.1-1.07.5-.37.4-1.4 1.36-1.4 3.32s1.44 3.85 1.64 4.12c.2.27 2.78 4.44 6.84 6.05 3.38 1.34 4.07 1.07 4.8 1.01.73-.06 2.36-.96 2.7-1.9.33-.93.33-1.73.23-1.9-.1-.17-.37-.27-.77-.47s-2.37-1.17-2.74-1.3c-.37-.14-.63-.2-.9.2-.27.4-.73.93-.9 1.13-.17.2-.33.22-.7.07-.37-.17-1.56-.57-2.97-1.83-1.1-.98-1.84-2.19-2.06-2.56-.21-.37-.02-.57.16-.75.16-.16.37-.42.56-.63.18-.2.24-.34.37-.57.12-.23.06-.43-.03-.63-.1-.2-.87-2.1-1.2-2.87z" fill="currentColor"/>
      </svg>
      Abrir WhatsApp
    </a>

    <h2 style="margin-top: 48px;">Categorías</h2>
    <p>¿Ya sabes qué producto te interesa? Visita directamente:</p>
    <ul style="list-style: none; display: flex; flex-direction: column; gap: 10px; margin-top: 8px;">
      {CATEGORIAS.map(cat => (
        <li>
          <a
            href={`/${cat.slug}`}
            style="color: var(--color-accent); font-weight: 600; font-size: 1rem;"
          >
            → {cat.nombre}
          </a>
        </li>
      ))}
    </ul>

    <!-- Redes sociales -->
    <h2 style="margin-top: 48px;">Síguenos</h2>
    <p>Encuéntranos en redes sociales para ver los últimos diseños y novedades:</p>
    <div class="contact-social">
      <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer" class="contact-social__btn contact-social__btn--ig" aria-label="Seguir en Instagram">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="currentColor" stroke-width="2"/>
          <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
        </svg>
        Instagram
      </a>
      <a href={SOCIAL.facebook} target="_blank" rel="noopener noreferrer" class="contact-social__btn contact-social__btn--fb" aria-label="Seguir en Facebook">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Facebook
      </a>
      <a href={SOCIAL.tiktok} target="_blank" rel="noopener noreferrer" class="contact-social__btn contact-social__btn--tt" aria-label="Seguir en TikTok">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        TikTok
      </a>
    </div>

    <h2 style="margin-top: 48px;">Ubicación</h2>
    <p>{SITE.city}, {SITE.country} — Envíos a todo Ecuador</p>

    <div class="contacto-map">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d255287.1308671855!2d-78.64400960000002!3d-0.18068920000001!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91d59a4002427c9f%3A0x44b991e158ef5572!2sQuito%2C%20Ecuador!5e0!3m2!1ses!2sec!4v1700000000000!5m2!1ses!2sec"
        width="100%"
        height="360"
        style="border:0; border-radius: 12px;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Joyería Salomé - Quito, Ecuador"
      ></iframe>
    </div>

  </div>

</BaseLayout>

<style>
  .contact-social {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 20px;
  }

  .contact-social__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 24px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.95rem;
    color: white;
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }

  .contact-social__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.2);
  }

  .contact-social__btn--ig {
    background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
  }

  .contact-social__btn--fb {
    background: #1877F2;
  }

  .contact-social__btn--tt {
    background: #010101;
  }

  .contacto-map {
    margin: 20px 0 8px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }
</style>
