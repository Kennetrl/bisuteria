---
import { SITE } from '../config/site.ts';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  schema?: object;
  keywords?: string;
}

const {
  title,
  description = SITE.description,
  ogImage = SITE.ogImage,
  canonical,
  schema,
  keywords,
} = Astro.props;

const canonicalURL = canonical
  ? new URL(canonical, SITE.url)
  : new URL(Astro.url.pathname, SITE.url);

const siteName = SITE.name || 'Joyería Salomé';
const fullTitle = `${title} | ${siteName}`;
const defaultKeywords = "joyería de acero inoxidable, joyas que no se oxidan, pulseras que duren, joyas resistentes al agua, accesorios de buena calidad, acero quirúrgico 316L, joyería Quito Ecuador";
const pageKeywords = keywords ? `${keywords}, ${defaultKeywords}` : defaultKeywords;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Primario -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={new URL(ogImage, SITE.url)} />
    <meta property="og:locale"      content={SITE.locale} />
    <meta property="og:site_name"   content={siteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={new URL(ogImage, SITE.url)} />

    <!-- Geo -->
    <meta name="geo.region"      content="EC-P" />
    <meta name="geo.placename"   content={SITE.city} />

    <!-- JSON-LD Schema -->
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Keywords SEO -->
    <meta name="keywords" content={pageKeywords} />

    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="/logo.webp" />

    <!-- Google Analytics -->
    {SITE.analytics && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.analytics}`}></script>
        <script define:vars={{ gaId: SITE.analytics }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />

    <!-- Fade-in on scroll -->
    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08 });

      document.querySelectorAll(
        'main h2, main h3, main p, main .product-card, main .feature, main .category-card, main .gallery-item, main .seo-intro, main .breadcrumb, main .content-page h2, main .content-page p'
      ).forEach(el => {
        el.classList.add('fade-in');
        observer.observe(el);
      });
    </script>
  </body>
</html>
